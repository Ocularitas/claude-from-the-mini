# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Per-machine agent state (not for repo)
.claude/
.telecontrol/
.telecontrol_session.mcp

# Defensive sensitive-file coverage (added 2026-05-17 security audit)
# Private keys (SSH, TLS)
*.key
*.p12
*.pfx
*.crt
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
id_ecdsa
id_ecdsa.pub
id_dsa

# Credential files
credentials.json
credentials.yml
credentials.yaml
.npmrc
.pypirc
.netrc
.docker/config.json
.kube/config
.aws/

# Token files
*.token
.gh_token

# Extra env variants
.env.production
.env.staging
.env.*.local
